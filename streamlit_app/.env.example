# 필수
OPENAI_API_KEY=

# 선택 — NewsAPI.org technology 헤드라인을 RSS 수집에 병합
# NEWS_API_KEY=
# (호환) NEWSAPI_API_KEY=

# --- Streamlit Community Cloud ---
# Secrets UI에는 TOML로 넣습니다. 최상위 키 권장:
#   OPENAI_API_KEY = "sk-..."
#   NEWS_API_KEY = "..."   # 선택
# 또는:
#   [openai]
#   api_key = "sk-..."
# 저장 후 앱 Reboot 필요할 수 있음.
