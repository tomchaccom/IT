# 필수
OPENAI_API_KEY=

# 선택 — NewsAPI.org technology 헤드라인을 RSS 수집에 병합
# NEWS_API_KEY=
# (호환) NEWSAPI_API_KEY=

# --- Streamlit Community Cloud ---
# Secrets UI에는 TOML로 넣습니다. 최상위 키 권장:
#   OPENAI_API_KEY = "sk-..."
#   NEWS_API_KEY = "..."   # 선택
# 또는 (섹션은 dict가 아니라 Mapping으로 읽힘 — 앱에서 매핑 처리함):
#   [openai]
#   api_key = "sk-..."
#
# 주의: 최상위에 openai_api_key만 두면 OS 환경 변수도 그 이름으로만 설정되므로,
# 앱이 OPENAI_API_KEY로 복사합니다. 가장 확실한 것은 첫 줄처럼 OPENAI_API_KEY를 쓰는 것.
# 저장 후 앱 Reboot.
